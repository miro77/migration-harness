# Harness configuration — edit these for your project.
# Sourced by the gate scripts and hooks. Keep it POSIX-shell-parseable
# (simple VAR="..." lines, no logic).

# Paths whose changes require a recorded gate proof before a turn may end.
# Space-separated, relative to the repo root; files and directories both work.
#
# Include your target/new source tree, the migration/ dir, the harness itself
# - AND the gates' own INPUTS: build/CI scripts, CI config files, vendored
# tool binaries the gates execute, and the frozen oracle tree. A proof that
# does not cover the programs that define the proof can be laundered by
# editing those programs (found by external review on a real migration).
#
# Every entry must be stageable by git: an entry inside a gitignored
# directory makes the hash tool fail closed (it names the entry; fix with a
# '!/path/' re-include in .gitignore or drop the entry).
#
# LIMITATION: all HARNESS_* path lists are space-separated - paths that
# themselves contain spaces are not supported.
HARNESS_SCOPE="src migration .claude CLAUDE.md AGENTS.md"

# Which profile drives the loop: "migration" (parity-matrix.md,
# /migrate-slice) or "feature" (spec-matrix.md, /feature-slice). Consumed by
# the tick/loop prompts and the completion validator (check-complete.sh).
HARNESS_PROFILE="migration"

# In-place oracle enforcement (docs/IN-PLACE-PROFILE.md): set to "baselines"
# to make gates.sh run check-matrix.sh + check-baselines.sh on every gate
# run. check-baselines.sh ships with a CONFIGURE step for your test-result
# format and fails until configured — deliberately.
HARNESS_ORACLE=""

# Frozen oracle paths — edits under these are blocked at PreToolUse time.
# These are the legacy sources you are migrating AWAY from; they must stay
# byte-identical so they remain a trustworthy reference/oracle. Space-separated
# path fragments, matched anywhere in the target file path (e.g. "legacy/src"
# blocks any file whose path contains "legacy/src"). Leave empty to disable.
HARNESS_FROZEN="legacy/src"

# Locked enforcement files — the harness's OWN gates, hooks, and config.
# Blocked at PreToolUse time against BOTH Edit/Write AND Bash writes
# (redirects, tee/cp/mv, sed -i). This stops the agent from neutering its own
# gates (e.g. rewriting gates.sh to a no-op, then recording a valid proof) or
# disabling the Stop hook. Executing/reading these stays allowed, so
# `bash migration/tools/gates.sh` and `cat`/`grep` still work.
#
# Same fragment-substring matching as HARNESS_FROZEN. Leave empty to disable.
#
# "Mutation" includes DELETION and reversion (rm, git rm, git checkout --,
# git restore, chmod): a Stop hook that is not on disk does not run, so deleting
# an enforcement file is a total bypass that writes no byte. Keep
# migration/frozen-baseline.sha in this list — it is the recorded reference the
# oracle is checked against, and an agent that can rewrite it can launder drift.
#
# BOOTSTRAP: the hooks only block the AGENT (Claude's Edit/Write/Bash tools),
# never a human editing in their own terminal/IDE. Configure gates.sh for your
# stack as a human FIRST; after that these are read-only to the agent. To let
# the agent reconfigure them later, a human must clear this var (which is itself
# locked — the agent cannot unlock itself).
HARNESS_LOCKED="migration/tools/ .claude/hooks/ .claude/settings.json .claude/settings.local.json migration/harness.env migration/frozen-baseline.sha"

# Oracle-linkage scan (opt-in; consumed by check-frozen.sh). A frozen oracle
# stops the agent EDITING the reference — it does not stop the new code from
# CALLING it. A port that shells out to the legacy binary, or links the legacy
# library, passes every parity fixture perfectly while having migrated nothing.
#
# Set this to your TARGET source paths (space-separated) to fail the gate when
# they reference any HARNESS_FROZEN fragment. Scan ONLY the new implementation:
# migration/ and the docs name the oracle legitimately and would false-positive.
# Leave empty to disable. Example: HARNESS_LINKAGE_SCAN="src"
HARNESS_LINKAGE_SCAN=""

# Per-session tool-call budget (PostToolUse telemetry hook). When the agent
# exceeds this many tool calls in a single session, a wrap-up warning is
# injected (the analogue of CallBudgetMiddleware). Leave empty or 0 to
# disable. Default: 200. In --drive mode each tick is a fresh session, so
# this is effectively a per-tick budget.
HARNESS_MAX_CALLS_PER_TICK="200"

# Loop detection (PostToolUse telemetry hook). If the same tool+args
# fingerprint appears this many times in the sliding window, a
# reconsideration prompt is injected (the analogue of
# LoopDetectionMiddleware). Leave 0 to disable. Default: 3.
HARNESS_LOOP_THRESHOLD="3"

# Sliding window size for loop detection (number of recent tool calls
# tracked). Default: 6.
HARNESS_LOOP_WINDOW="6"

# Driver tick budget: max fresh-context ticks one `kick-loop.sh --drive` run
# spends before returning (state stays checkpointed on disk; re-run to
# continue). An environment variable on the invocation overrides this.
# Default: 50.
HARNESS_MAX_TICKS="50"

# Stale-lock recovery TTL in minutes: a kick-loop.sh lock older than this is
# treated as left behind by a crashed run and recovered. Default: 360.
HARNESS_LOCK_TTL_MIN="360"

# Runtime-stub gate (opt-in; consumed by migration/tools/check-stubs.sh via
# gates.sh). If your migrated app ships a placeholder path the user can hit — a
# "not implemented" stub for a feature deferred to a later slice — set
# STUB_SENTINEL to an extended-regex matching that placeholder string, and
# STUB_SCAN to the shipped-source paths to scan (space-separated; NOT tests).
# Then every stub must be registered in migration/integration-ledger.md and
# tagged inline with its INTEG-<id>, or the gate fails. Leave STUB_SENTINEL empty
# to disable (fine if your app never ships a user-reachable placeholder). Example:
#   STUB_SENTINEL="not yet implemented|UnimplementedError"
#   STUB_SCAN="app/lib"
STUB_SENTINEL=""
STUB_SCAN=""
