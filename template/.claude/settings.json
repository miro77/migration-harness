{
  "permissions": {
    "allow": [
      "Bash(bash migration/tools/gates.sh:*)",
      "Bash(bash migration/tools/kick-loop.sh:*)",
      "Bash(bash migration/tools/doctor.sh:*)",
      "Bash(bash migration/tools/check-docs.sh:*)",
      "Bash(bash migration/tools/check-frozen.sh:*)",
      "Bash(bash migration/tools/check-complete.sh:*)",
      "Bash(bash migration/tools/record-audit.sh:*)",
      "Bash(bash migration/tools/working-tree-hash.sh:*)",
      "Bash(bash migration/tools/persist-state.sh:*)",
      "Bash(bash migration/tools/read-state.sh:*)",
      "Bash(bash migration/tools/benchmark.sh:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pretooluse-command-guard.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pretooluse-frozen-legacy.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/posttooluse-telemetry.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-require-gates.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/precompact-checkpoint.sh\""
          }
        ]
      }
    ]
  }
}
